APP_NAME="AlgoRAG"
APP_VERSION="0.1"

FILE_ALLOWED_TYPES=["text/plain", "application/pdf"]
FILE_MAX_SIZE=10
FILE_DEFAULT_CHUNK_SIZE=512000
TEXT_CHUNK_SIZE=800
TEXT_CHUNK_OVERLAP=120

POSTGRES_USERNAME="postgres"
POSTGRES_PASSWORD="algorag2222"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_MAIN_DATABASE="algorag"

# ========================= Generation (LLM) =========================
# GENERATION_BACKEND: DEEPSEEK | OPENAI | COHERE | VERTEX
GENERATION_BACKEND=VERTEX

# DeepSeek V4 Flash — cloud API (OpenAI-compatible)
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_URL=https://api.deepseek.com

GENERATION_MODEL_ID=gemini-2.5-flash
GENERATION_MODEL_ID_LITERAL=["deepseek-v4-flash","deepseek-v4-pro","gpt-4o-mini","gpt-4o","gemini-2.5-flash"]

# Alternate generation providers (uncomment backend + keys to switch)
# GENERATION_BACKEND=OPENAI
# OPENAI_API_KEY=sk-
# OPENAI_API_URL=
# GENERATION_BACKEND=COHERE
# COHERE_API_KEY=
# GENERATION_BACKEND=VERTEX
# VERTEX_PROJECT_ID=algo-rag
# VERTEX_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=

INPUT_DAFAULT_MAX_CHARACTERS=1024
GENERATION_DAFAULT_MAX_TOKENS=2048
GENERATION_DAFAULT_TEMPERATURE=0.1

# ========================= Embedding =========================
# EMBEDDING_BACKEND: BGE | OPENAI | COHERE | VERTEX
EMBEDDING_BACKEND=BGE

# BGE-M3 — local (FlagEmbedding; GPU strongly recommended)
EMBEDDING_MODEL_ID=BAAI/bge-m3
EMBEDDING_MODEL_SIZE=1024

# Alternate embedding providers
# EMBEDDING_BACKEND=COHERE
# EMBEDDING_MODEL_ID=embed-multilingual-light-v3.0
# EMBEDDING_MODEL_SIZE=384
# EMBEDDING_BACKEND=VERTEX
# EMBEDDING_MODEL_ID=text-multilingual-embedding-002
# EMBEDDING_MODEL_SIZE=768

# ========================= Vector DB =========================
VECTOR_DB_BACKEND_LITERAL=["QDRANT","PGVECTOR"]
VECTOR_DB_BACKEND=PGVECTOR
VECTOR_DB_PATH=qdrant_db
VECTOR_DB_DISTANCE_METHOD=cosine
VECTOR_DB_PGVEC_INDEX_THRESHOLD=100

# ========================= OCR =========================
# OCR_ENGINE: docling | gemini
# docling — Docling + RapidOCR Paddle backend (pip install rapidocr-paddle)
# gemini  — Vertex AI vision (requires VERTEX_PROJECT_ID + credentials)
OCR_ENGINE=docling
OCR_IMAGE_SCALE=1.5
OCR_PAGE_TIMEOUT_SECONDS=120
OCR_GEMINI_MODEL_ID=

# ========================= Language =========================
PRIMARY_LANG=ar
DEFAULT_LANG=en

# ========================= Reranker =========================
# RAG_RERANKER_BACKEND: bge | cohere
RAG_ENABLE_RERANKER=true
RAG_RERANKER_BACKEND=bge
BGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANKER_DEVICE=cpu
RAG_RERANKER_BATCH_SIZE=8
RAG_RERANKER_USE_FP16=false
RAG_RERANKER_MAX_CHARS=1024
RAG_RERANKER_WARMUP_ON_STARTUP=true
# Benchmark local CPU settings (run from src/):
# python scripts/benchmark_bge_reranker.py
# COHERE_RERANKER_MODEL=rerank-multilingual-v3.0
# RAG_RERANKER_TOP_N=

# ========================= Celery =========================
CELERY_BROKER_URL="amqp://algorag_user:algorag_rabbitmq_2222@localhost:5672/algorag_vhost"
CELERY_RESULT_BACKEND="redis://:algorag_redis_2222@localhost:6379/0"
CELERY_TASK_SERIALIZER=json
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_ACKS_LATE=false
CELERY_WORKER_CONCURRENCY=3
CELERY_FLOWER_PASSWORD="algorag_flower_2222"

# ========================= RAG Performance =========================
LLM_USE_ASYNC=true
RAG_PROMPT_CHAR_BUDGET=0

# Hybrid retrieval: run dense vector search + PostgreSQL full-text search
# concurrently and fuse them via classical Reciprocal Rank Fusion (RRF).
# RAG_ENABLE_HYBRID_SEARCH is the master toggle; RAG_ENABLE_BM25 is kept
# as a legacy alias (consulted only when RAG_ENABLE_HYBRID_SEARCH is unset).
RAG_ENABLE_HYBRID_SEARCH=true
RAG_ENABLE_BM25=true

# Candidate window: both dense and sparse retrieval fetch this many
# candidates. The fused result is narrowed to this count before
# cross-encoder reranking. Do not reduce before reranking.
RAG_RETRIEVAL_CANDIDATES=30

# Classical RRF constant (k). Higher values dampen the influence of
# top-ranked documents. Default 60 follows Cormack et al.
RAG_RRF_K=60

# Over-fetch multiplier used only by expansion queries.
RAG_RETRIEVAL_FETCH_MULTIPLIER=3

# Max documents returned by the cross-encoder reranker (final Top-N
# passed to the LLM). 0 / None = return all candidates (re-ordered).
RAG_RERANKER_TOP_N=5

RAG_HISTORY_MODE=auto
